<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="THÊM THUỐC MỚI"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#00A896"
        android:gravity="center"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/edtTenThuoc"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Tên loại thuốc"
        android:paddingLeft="15dp"
        android:layout_marginBottom="15dp"
        android:background="@android:drawable/edit_text"/>

    <EditText
        android:id="@+id/edtGiaBan"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Giá bán (VNĐ)"
        android:inputType="number"
        android:paddingLeft="15dp"
        android:layout_marginBottom="15dp"
        android:background="@android:drawable/edit_text"/>

    <EditText
        android:id="@+id/edtSoLuong"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Số lượng nhập kho"
        android:inputType="number"
        android:paddingLeft="15dp"
        android:layout_marginBottom="30dp"
        android:background="@android:drawable/edit_text"/>

    <Button
        android:id="@+id/btnLuuThuoc"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="LƯU VÀO KHO"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnHuyAdd"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="HỦY BỎ"
        android:backgroundTint="#B0BEC5"
        android:textColor="#333333"
        android:textStyle="bold"/>

</LinearLayout>